
    <!-- Trip Planning Form -->
    <div id="form" class="max-w-7xl mx-auto grid md:grid-cols-2 gap-6 bg-white shadow-lg rounded-xl
p-6 animate-fadeIn md:mt-8 md:mb-10">
        <!-- Left Section -->
        <div class="md:order-2 md:border-l-2 border-gray-300 md:p-20">
            <div class="flex justify-between items-center m-5">
                <h1 class="text-xl font-bold text-teal-600">Trip Planner</h1>
                <button class="text-xl text-blue-600">&#9776;</button>
            </div>
            <form class="space-y-4 animate-slideUp">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="block">
                        <span class="text-gray-700">Destination Type</span>
                        <select
                            class="mt-1 block w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-400">
                            <option>Domestic</option>
                            <option>International</option>
                        </select>
                    </label>
                    <label class="block">
                        <span class="text-gray-700">Budget (USD)</span>
                        <input type="number"
                            class="mt-1 block w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-400"
                            placeholder="Enter your budget">
                    </label>
                </div>
                <label class="block">
                    <span class="text-gray-700">Health Condition</span>
                    <input type="text"
                        class="mt-1 block w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-400"
                        placeholder="Enter any health considerations">
                </label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="block">
                        <span class="text-gray-700">Age</span>
                        <input type="number"
                            class="mt-1 block w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-400"
                            placeholder="Enter your age">
                    </label>
                    <label class="block">
                        <span class="text-gray-700">Number of Days</span>
                        <input type="number"
                            class="mt-1 block w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-400"
                            placeholder="How many days can you spend?">
                    </label>
                </div>
                <button type="submit"
                    class="w-full bg-teal-500 text-white p-3 rounded-md hover:bg-teal-600 transition duration-300 shadow-md">Get
                    <a href="/place">Recommendations</a></button>
            </form>
            
        </div>

        
        <div class="text-center max-w-3xl h-1lg md:order-1">
            <dotlottie-player class="md:max-w-3xl"
                src="https://lottie.host/e637bfa7-350f-4b64-9e4a-a00991377a70/lDVwHHchUs.lottie"
                background="transparent" speed="0.3" loop autoplay></dotlottie-player>
        </div>
    </div>
<main class="max-w-6xl mx-auto mt-10 px-4 md:px-0 py-10">
    <section id="features" class="bg-gray-300 p-6 rounded-lg shadow-md text-center">
        <h2 class="text-4xl font-bold">Adventure of your lifetime</h2>
        <p class="text-gray-600 mt-4">Explore scenic trails to magnificent waterfalls, surrounded by lush landscapes.
        </p>
        <div class="mt-6 space-x-4">
            <button class="bg-black text-white px-6 py-3 rounded hover:bg-gray-800">Reserve a spot</button>
            <button class="border border-black px-6 py-3 rounded hover:bg-gray-200">Get a consultation</button>
        </div>
    </section>

    <section id="program" class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-10">
        <div class="bg-gray-200 p-6 rounded-lg text-center">
            <h3 class="text-2xl font-bold">10k+</h3>
            <p>Happy customers</p>
        </div>
        <div class="bg-gray-200 p-6 rounded-lg text-center">
            <h3 class="text-2xl font-bold">1k+</h3>
            <p>Wonderful adventures</p>
        </div>
        <div class="bg-gray-200 p-6 rounded-lg text-center">
            <h3 class="text-2xl font-bold">10+</h3>
            <p>Waterfalls were visited</p>
        </div>
    </section>

    <section id="reviews" class="mt-10 bg-gray-300 p-6 rounded-lg">
        <h2 class="text-3xl font-bold text-center">What our customers feel about us</h2>
        <p class="text-center mt-4">Our customers rave about our exceptional service, quality, and the positive impact
            on their experiences.</p>
    </section>

    <section id="faq" class="mt-10">
        <h2 class="text-3xl font-bold text-center">Frequently Asked Questions</h2>
        <div class="mt-6 max-w-3xl mx-auto">
            <details class="bg-gray-200 p-4 rounded mb-4">
                <summary class="cursor-pointer text-lg font-bold">What is Nourish?</summary>
                <p class="mt-2">Nourish is a travel experience company providing scenic trips.</p>
            </details>
            <details class="bg-gray-200 p-4 rounded mb-4">
                <summary class="cursor-pointer text-lg font-bold">Where is the next trip?</summary>
                <p class="mt-2">Italian Dolomites: Scenic mountains, charming villages, and breathtaking landscapes.</p>
            </details>
            <details class="bg-gray-200 p-4 rounded mb-4">
                <summary class="cursor-pointer text-lg font-bold">What equipment do I need?</summary>
                <p class="mt-2">Basic hiking gear, comfortable clothing, and a sense of adventure.</p>
            </details>
        </div>
    </section>

    <section id="contacts" class="mt-10 bg-gray-300 p-6 rounded-lg text-center">
        <h2 class="text-3xl font-bold">Get in touch</h2>
        <p class="mt-2">We're here to help you embark on your next adventure.</p>
        <form class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl mx-auto">
            <input type="text" placeholder="First Name" class="p-3 border rounded">
            <input type="text" placeholder="Last Name" class="p-3 border rounded">
            <input type="email" value="dpk.41deep@gmail.com" readonly
                class="border p-2 rounded-lg text-gray-500 cursor-not-allowed">
            <textarea placeholder="Your Message" class="p-3 border rounded col-span-2"></textarea>
            <button class="bg-black text-white px-6 py-3 rounded col-span-2 hover:bg-gray-800">Send Message</button>
        </form>
    </section>
</main>
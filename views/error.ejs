<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Found</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="flex flex-col items-center justify-center min-h-screen bg-gray-700 text-white p-6">

    <div class="text-center space-y-4">
        <h1 class="text-7xl font-bold text-red-500">404</h1>
        <p class="text-xl">Oops! The page you’re looking for doesn’t exist.</p>

        <div class="bg-gray-800 p-4 rounded-lg text-gray-500">
            <p><span class="font-semibold text-white">Incorrect URL:</span> <%= req.originalUrl %></p>
            <p><span class="font-semibold text-white">Method:</span> <%= req.method %></p>
            <p><span class="font-semibold text-white">User Agent:</span> <%= req.headers['user-agent'] %></p> 
        </div>

        <a href="/" class="inline-block px-6 py-2 text-lg font-semibold text-blue-400 border border-blue-400 rounded-md hover:bg-blue-400 hover:text-white transition duration-300">
            Go Home
        </a>
    </div>

</body>
</html>
